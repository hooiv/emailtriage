@app.post("/email-rules/{rule_id}/toggle")
@limiter.limit("50/minute")
async def toggle_email_rule(request: Request, rule_id: str):
    """Toggle an email rule active/inactive."""
    if not env._initialized:
        raise HTTPException(status_code=400, detail="Environment not initialized. Call /reset first.")
    
    rule = next((r for r in env.email_rules if r.id == rule_id), None)
    if not rule:
        raise HTTPException(status_code=404, detail="Rule not found")
    
    rule.is_active = not rule.is_active
    
    env._add_audit_log("rule_toggled", None, {
        "rule_id": rule_id,
        "rule_name": rule.name,
        "new_status": "active" if rule.is_active else "inactive"
    })
    
    return {
        "success": True,
        "rule_id": rule_id,
        "is_active": rule.is_active
    }


@app.get("/performance")
@limiter.limit("100/minute")
async def get_performance_metrics(request: Request):
    """Get real-time performance metrics and optimization suggestions."""
    if not env._initialized:
        raise HTTPException(status_code=400, detail="Environment not initialized. Call /reset first.")
    
    import psutil
    import os
    
    # Get system metrics
    process = psutil.Process(os.getpid())
    env.performance_metrics.cpu_usage_percent = process.cpu_percent()
    env.performance_metrics.memory_usage_mb = process.memory_info().rss / 1024 / 1024
    
    # Calculate API calls per minute
    current_time = time.time()
    recent_requests = len([t for t in env._request_times if current_time - t < 60])
    env.performance_metrics.api_calls_per_minute = recent_requests
    
    return {
        "performance": env.performance_metrics.model_dump(),
        "uptime_seconds": current_time - env._start_time,
        "total_requests": env.metrics.total_requests
    }


@app.get("/team-members")
@limiter.limit("100/minute")
async def get_team_members(request: Request):
    """Get all team members."""
    if not env._initialized:
        raise HTTPException(status_code=400, detail="Environment not initialized. Call /reset first.")
    
    return {
        "members": [member.model_dump() for member in env.team_members.values()],
        "count": len(env.team_members)
    }


@app.post("/team-members")
@limiter.limit("20/minute")
async def add_team_member(request: Request, member_data: dict):
    """Add a new team member."""
    if not env._initialized:
        raise HTTPException(status_code=400, detail="Environment not initialized. Call /reset first.")
    
    try:
        member_id = env.add_team_member(
            name=member_data["name"],
            email=member_data["email"],
            role=member_data.get("role", "agent")
        )
        
        return {
            "success": True,
            "member_id": member_id,
            "message": f"Team member {member_data[\"name\"]} added"
        }
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"Failed to add team member: {str(e)}")


@app.get("/analytics/summary")
@limiter.limit("100/minute")
async def get_analytics_summary(request: Request):
    """Get comprehensive analytics summary."""
    if not env._initialized:
        raise HTTPException(status_code=400, detail="Environment not initialized. Call /reset first.")
    
    # Email statistics
    total_emails = len(env.emails)
    processed_emails = sum(1 for e in env.emails if e.category is not None)
    spam_emails = sum(1 for e in env.emails if e.is_spam)
    flagged_emails = sum(1 for e in env.emails if e.is_flagged)
    
    # Response statistics
    replied_emails = sum(1 for e in env.emails if e.reply_sent)
    forwarded_emails = sum(1 for e in env.emails if e.forwarded_to)
    
    # Time statistics
    avg_processing_time = env.metrics.avg_response_time_ms
    
    # Rule statistics
    active_rules = sum(1 for r in env.email_rules if r.is_active)
    total_rule_applications = sum(r.applications_count for r in env.email_rules)
    
    return {
        "email_stats": {
            "total": total_emails,
            "processed": processed_emails,
            "spam": spam_emails,
            "flagged": flagged_emails,
            "processing_rate": processed_emails / total_emails if total_emails > 0 else 0
        },
        "action_stats": {
            "replied": replied_emails,
            "forwarded": forwarded_emails,
            "actions_taken": env.metrics.actions_taken
        },
        "performance_stats": {
            "avg_response_time_ms": avg_processing_time,
            "total_requests": env.metrics.total_requests,
            "sla_violations": env.metrics.sla_violations
        },
        "automation_stats": {
            "active_rules": active_rules,
            "rule_applications": total_rule_applications,
            "tags_used": len(env.tags_used)
        },
        "team_stats": {
            "members": len(env.team_members),
            "audit_entries": len(env.audit_log)
        }
    }

